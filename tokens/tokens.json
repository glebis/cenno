{
  "color": {
    "flow": {
      "mood":     { "$type": "color", "$value": "#FF6250", "$description": "Coral — mood check-ins" },
      "question": { "$type": "color", "$value": "#1E4FD8", "$description": "Cobalt — free-text and choice questions" },
      "ema":      { "$type": "color", "$value": "#0E7C6B", "$description": "Teal — EMA multi-step flows" },
      "reminder": { "$type": "color", "$value": "#4A5568", "$description": "Slate — reminders" },
      "ambient":  { "$type": "color", "$value": "#14171A", "$description": "Ink — expired states, tray inbox/history" }
    },
    "paper": { "$type": "color", "$value": "#FAF8F5", "$description": "Docs/specimen background" },
    "text": {
      "default": { "$type": "color", "$value": "#FFFFFF", "$description": "Primary text on flow colors" },
      "dim": { "$type": "color", "$value": "rgba(255,255,255,0.6)", "$description": "Secondary text — 60% white" }
    },
    "line": { "$type": "color", "$value": "rgba(255,255,255,0.4)", "$description": "Underlines, hairlines, outlines — 40% white" }
  },
  "type": {
    "question": {
      "l": { "$type": "dimension", "$value": "44px", "$description": "Fullscreen questions" },
      "m": { "$type": "dimension", "$value": "22px", "$description": "Panel questions" }
    },
    "body":    { "$type": "dimension", "$value": "17px", "$description": "Answers, choices" },
    "caption": { "$type": "dimension", "$value": "13px", "$description": "Captions, metadata, dB indicator" }
  },
  "space": {
    "1": { "$type": "dimension", "$value": "8px" },
    "2": { "$type": "dimension", "$value": "16px" },
    "3": { "$type": "dimension", "$value": "24px" },
    "4": { "$type": "dimension", "$value": "40px" },
    "5": { "$type": "dimension", "$value": "64px" }
  },
  "radius": {
    "control": { "$type": "dimension", "$value": "10px", "$description": "Inputs/cards" },
    "pill":    { "$type": "dimension", "$value": "999px", "$description": "Pill chips" }
  }
}
