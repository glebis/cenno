{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "cenno",
  "version": "0.3.1",
  "identifier": "app.cenno",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1430",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "cenno",
        "width": 420,
        "height": 240,
        "acceptFirstMouse": true,
        "decorations": false,
        "alwaysOnTop": true,
        "visible": false,
        "backgroundColor": "#14171a"
      }
    ],
    "security": {
      "csp": "default-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' data:; font-src 'self'"
    }
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/glebis/cenno/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEZCQzAzRDFDMTY1ODUzRjIKUldUeVUxZ1dIRDNBKzZhWmxEWWo4ZUJ3RWVUSnVxNFNDNTMvc2drRGFBcTVKRlNqZ1JWQWwvcVoK"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "hardenedRuntime": true,
      "minimumSystemVersion": "12.0",
      "entitlements": "./Entitlements.plist"
    }
  }
}
