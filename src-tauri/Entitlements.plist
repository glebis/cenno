<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<!-- Hardened-runtime apps need this for the microphone TCC prompt to
	     appear at all; without it AVCaptureDevice denies silently. -->
	<key>com.apple.security.device.audio-input</key>
	<true/>
	<!-- iCloud/CloudKit entitlements were REMOVED in 0.3.1. They are RESTRICTED
	     entitlements that macOS AMFI only honours when the bundle ships an
	     embedded.provisionprofile authorizing them. A Developer-ID (non-App-Store)
	     build has no such profile, so AMFI SIGKILLs the app at launch
	     ("Launchd job spawn failed", exit 137) — this bricked 0.3.0. The CloudKit
	     relay is already gated to run without the entitlement, so dropping these
	     only disables a relay that could not publish from a shipped build anyway.
	     To re-enable CloudKit on the Mac build later: generate a Developer ID
	     provisioning profile that includes the iCloud.app.cenno container, embed
	     it at Contents/embedded.provisionprofile, and re-add these keys:
	       com.apple.application-identifier                  79SP7TM5PH.app.cenno
	       com.apple.developer.team-identifier               79SP7TM5PH
	       com.apple.developer.icloud-container-identifiers  [iCloud.app.cenno]
	       com.apple.developer.icloud-services               [CloudKit] -->
</dict>
</plist>
