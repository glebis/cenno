        z-index: 5;
      }
      /* 8px visual dot inside a ≥44px tap target (brand rule). */
      .dot {
        display: grid; place-items: center;
        width: calc(8px + var(--cenno-space-1) * 2); min-width: 24px;
        height: 44px;
      }
      .dot::before {
        content: "";
        width: 8px; height: 8px;
        border-radius: var(--cenno-radius-pill);
        background: var(--cenno-color-text-default);
        opacity: 0.4;
        transition: opacity 0.3s, transform 0.3s;
      }
      .dot.on::before { opacity: 1; transform: scale(1.25); }
      .dots-ink .dot::before { background: var(--cenno-color-flow-ambient); }
      .dot:focus-visible { outline: 2px solid currentColor; outline-offset: 3px; }

      /* ——— motion: the mark beckons, content answers ———————— */
      :root {
        --ease-out-quart: cubic-bezier(0.25, 1, 0.5, 1);
        --ease-out-expo: cubic-bezier(0.16, 1, 0.3, 1);
      }
      @keyframes draw-arc {
        from { stroke-dashoffset: 100; }
        to { stroke-dashoffset: 0; }
      }
      @keyframes land-dot {
        from { opacity: 0; transform: translateY(-6px); }
        to { opacity: 1; transform: translateY(0); }
      }
      @keyframes rise {
        from { opacity: 0; transform: translateY(16px); }
        to { opacity: 1; transform: translateY(0); }
      }
      .mark-arc {
        stroke-dasharray: 100;
        animation: draw-arc 0.7s var(--ease-out-expo) 0.15s both;
      }
      .mark-dot {
        transform-box: fill-box;
        animation: land-dot 0.45s var(--ease-out-quart) 0.65s both;
      }
      .enter { animation: rise 0.6s var(--ease-out-quart) both; }
      .enter-1 { animation-delay: 0.25s; }
      .enter-2 { animation-delay: 0.4s; }
      .enter-3 { animation-delay: 0.55s; }
      .enter-4 { animation-delay: 0.7s; }
      .reveal {
        opacity: 0;
        transform: translateY(16px);
        transition: opacity 0.6s var(--ease-out-quart), transform 0.6s var(--ease-out-quart);
      }
      .reveal.in { opacity: 1; transform: none; }
      .copy-hint { transition: color 0.2s; }
      @media (prefers-reduced-motion: reduce) {
        .mark-arc, .mark-dot, .enter { animation: none; }
        .reveal { opacity: 1; transform: none; transition: none; }
        .btn, .dot { transition: none; }
        .btn:hover { transform: none; }
      }
      /* No-JS fallback: never hide content behind a class JS must add. */
      @media (scripting: none) {
        .reveal { opacity: 1; transform: none; }
      }

      /* ——— small screens ——————————————————————————————————— */
      @media (max-width: 640px) {
        .shot-offset { margin-top: 0; }
        .panel { padding-bottom: calc(var(--cenno-space-5) + var(--cenno-space-3)); }
      }
    </style>
  </body>
