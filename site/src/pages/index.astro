---
// cenno landing — every value comes from tokens/tokens.json via tokens.css.
// The page is structured like a cenno session: one question per screen,
// one flow color per panel, dot pagination fixed at the bottom.
import "../styles/tokens.css";

const GITHUB = "https://github.com/glebis/cenno";

// Resolve the latest *released* DMG at build time; fall back to a known
// release so the build never emits a 404 link (repo version may be ahead).
let VERSION = "0.1.0";
let DMG = `${GITHUB}/releases/download/v${VERSION}/cenno_${VERSION}_aarch64.dmg`;
try {
  const res = await fetch("https://api.github.com/repos/glebis/cenno/releases/latest", {
    headers: { Accept: "application/vnd.github+json" },
  });
  if (res.ok) {
    const rel = await res.json();
    const asset = rel.assets?.find((a: { name: string }) => a.name.endsWith(".dmg"));
    if (asset) {
      DMG = asset.browser_download_url;
      VERSION = String(rel.tag_name).replace(/^v/, "");
    }
  }
} catch {
  /* offline build → fallback link */
}
const BREW = "brew install --cask glebis/tap/cenno";
const TITLE = "cenno — agents ask. you answer.";
const DESCRIPTION =
  "cenno is a macOS menu-bar app that lets AI agents ask you questions through minimal floating panels — without stealing your focus. Your answer goes back as structured data; every exchange stays in a local database that is yours.";

const SKILL_URL = `${GITHUB}/tree/main/skills/cenno`;

const PROMPT_UX = `Install cenno if it isn't already:
  brew install --cask glebis/tap/cenno
  npx skills add glebis/claude-skills@cenno -g -y
Add cenno to this project's .mcp.json, then run a UX discovery interview — 6 questions:
  1. What's the most important problem you're working on right now? (text)
  2. Who are you building for? (choice: myself / a small team / customers / still figuring out)
  3. What does success look like in 3 months? (text)
  4. Where does your workflow break down most often? (text)
  5. How confident do you feel about the current direction? (scale 1–7)
  6. If you had to ship something tomorrow, what would you cut? (text)
Use the question flow theme. Return a structured summary with key signals.`;

const PROMPT_WELLBEING = `Install cenno if it isn't already:
  brew install --cask glebis/tap/cenno
  npx skills add glebis/claude-skills@cenno -g -y
Add cenno to this project's .mcp.json, then run a wellbeing check-in — 5 questions:
  1. How are you feeling right now? (choice: good / tired / stressed / anxious / calm)
  2. How did you sleep last night? (scale 1–7, 1 = terrible, 7 = great)
  3. Any physical tension or discomfort? (text)
  4. Is anything weighing on your mind? (text)
  5. What would help you most right now? (choice: a break / movement / food / talk to someone / just keep going)
Use the mood flow theme. Finish with a gentle summary — notice patterns, don't diagnose.`;

const PROMPT_GOALS = `Install cenno if it isn't already:
  brew install --cask glebis/tap/cenno
  npx skills add glebis/claude-skills@cenno -g -y
Add cenno to this project's .mcp.json, then run a goals alignment check-in — 5 questions:
  1. What's your single most important priority this week? (text)
  2. Are you working on it today? (confirm)
  3. How aligned does today feel with your longer-term goals? (scale 1–7)
  4. What keeps pulling you off track? (text)
  5. One thing worth protecting time for tomorrow? (text)
Use the reminder flow theme. Save answers to goals-checkin.md and return a short reflection.`;

const panels = [
  { id: "hero", flow: "mood", label: "Introduction" },
  { id: "panels", flow: "paper", label: "What it looks like" },
  { id: "how", flow: "reminder", label: "How it works" },
  { id: "wire", flow: "question", label: "Quickstart" },
  { id: "agents", flow: "ema", label: "Getting started for agents" },
  { id: "data", flow: "reminder", label: "Privacy and policy" },
  { id: "dev", flow: "paper", label: "For developers" },
  { id: "ship", flow: "ambient", label: "Download and links" },
];
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{TITLE}</title>
    <meta name="description" content={DESCRIPTION} />
    <link rel="canonical" href="https://cenno.salient.community/" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
    <meta name="theme-color" content="#ff6250" />
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="cenno" />
    <meta property="og:title" content={TITLE} />
    <meta property="og:description" content={DESCRIPTION} />
    <meta property="og:url" content="https://cenno.salient.community/" />
    <meta property="og:image" content="https://cenno.salient.community/og.png" />
    <meta property="og:image:width" content="1280" />
    <meta property="og:image:height" content="600" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:site" content="@glebkalinin" />
    <meta name="twitter:creator" content="@glebkalinin" />
    <meta name="twitter:title" content={TITLE} />
    <meta name="twitter:description" content={DESCRIPTION} />
    <meta name="twitter:image" content="https://cenno.salient.community/og.png" />
    <meta name="twitter:image:alt" content="cenno — agents ask. you answer." />
    <script
      type="application/ld+json"
      set:html={JSON.stringify({
        "@context": "https://schema.org",
        "@type": "SoftwareApplication",
        name: "cenno",
        operatingSystem: "macOS 12+",
        applicationCategory: "DeveloperApplication",
        offers: { "@type": "Offer", price: "0", priceCurrency: "EUR" },
        softwareVersion: VERSION,
        downloadUrl: DMG,
        license: "https://www.apache.org/licenses/LICENSE-2.0",
        author: { "@type": "Person", name: "Gleb Kalinin", url: "https://glebkalinin.de" },
        description: DESCRIPTION,
      })}
    />
    <noscript><style>.reveal { opacity: 1 !important; transform: none !important; }</style></noscript>
  </head>

  <body>
    <a class="skip" href="#hero">Skip to content</a>

    <!-- 1 · MOOD — the hero asks the only question that matters -->
    <section class="panel" id="hero" data-flow="mood" aria-label="Introduction">
      <header class="strip">
        <span class="lockup" aria-label="cenno">
          <svg class="mark" viewBox="0 0 22 22" width="22" height="22" aria-hidden="true">
            <path d="M 5.6874 7.5765 A 5.5 5.5 0 0 1 16.3126 7.5765" fill="none" stroke="currentColor" stroke-width="2.5"/>
            <circle cx="11" cy="16.25" r="2.75" fill="currentColor"/>
          </svg>
          cenno
        </span>
        <a class="strip-link" href={GITHUB}>GitHub&nbsp;&#8599;</a>
      </header>

      <div class="panel-body hero-body">
        <div class="hero-copy">
          <svg class="mark mark-xl" viewBox="0 0 22 22" aria-hidden="true">
            <path class="mark-arc" d="M 5.6874 7.5765 A 5.5 5.5 0 0 1 16.3126 7.5765" fill="none" stroke="currentColor" stroke-width="2.5" pathLength="100"/>
            <circle class="mark-dot" cx="11" cy="16.25" r="2.75" fill="currentColor"/>
          </svg>
          <h1 class="enter enter-1">agents ask.<br />you answer.</h1>
          <p class="lede enter enter-2">
            cenno gives MCP agents a polite way to reach you: a small panel slides
            over your work — without stealing your keyboard — you tap or type, and
            the agent gets a structured answer back.
          </p>
          <div class="cta-row enter enter-3">
            <a class="btn btn-solid" href={DMG}>Download for macOS</a>
            <button class="btn btn-ghost copy" data-copy={BREW} type="button">
              <code>{BREW}</code>
              <span class="copy-hint" role="status">copy</span>
            </button>
          </div>
          <p class="fine enter enter-4">
            Apple Silicon · macOS&nbsp;12+ · free &amp; open source
          </p>
        </div>

        <!-- interactive demo: the agent interviews you, one panel at a time -->
        <div class="demo enter enter-3" id="demo">
          <div class="demo-term" role="log" aria-label="Terminal transcript">
            <p><span class="t-dim">$</span> claude "interview me — learn my preferences"</p>
            <p class="t-dim">⏺ cenno · ask_user</p>
          </div>
          <div class="demo-panel" data-flow="question" aria-live="polite">
            <div class="demo-head">
              <span class="demo-brand">
                <svg viewBox="0 0 22 22" width="14" height="14" aria-hidden="true">
                  <path d="M 5.6874 7.5765 A 5.5 5.5 0 0 1 16.3126 7.5765" fill="none" stroke="currentColor" stroke-width="2.5"/>
                  <circle cx="11" cy="16.25" r="2.75" fill="currentColor"/>
                </svg>
                cenno
              </span>
              <span class="demo-x" aria-hidden="true">×</span>
            </div>
            <p class="demo-q"></p>
            <div class="demo-controls"></div>
            <div class="demo-dots" aria-hidden="true"></div>
          </div>
          <p class="fine demo-hint">Live demo — answer it yourself, or let it play.</p>
        </div>
      </div>
    </section>

    <!-- 2 · PAPER — show, don't tell -->
    <section class="panel" id="panels" data-flow="paper" aria-label="What it looks like">
      <div class="panel-body reveal">
        <p class="caption">What it looks like</p>
        <h2>One question per screen.<br />The answer is the interface.</h2>
        <div class="shots">
          <figure>
            <img src="/qa-mood.png" alt="cenno mood check-in panel: 'How are you feeling right now?' over a coral background with five mood words" width="840" height="480" loading="lazy" />
            <figcaption>A mood check-in. Tap a word, done.</figcaption>
          </figure>
          <figure class="shot-offset">
            <img src="/qa-scale.png" alt="cenno EMA scale panel: a 1-to-7 scale question on teal with dot pagination" width="840" height="480" loading="lazy" />
            <figcaption>A multi-step EMA flow with dot pagination.</figcaption>
          </figure>
        </div>
        <p class="etym">
          <em>Fare un cenno</em> — Italian: to give a small sign. To nod, to
          mention briefly, to beckon silently. That's the whole interaction
          model: agents make a small sign, you answer with one.
        </p>
      </div>
    </section>

    <!-- 3 · REMINDER — how it works -->
    <section class="panel" id="how" data-flow="reminder" aria-label="How it works">
      <div class="panel-body reveal">
        <p class="caption">How it works</p>
        <h2>Three small signs.</h2>
        <ol class="steps">
          <li>
            <span class="step-n">01</span>
            <h3>The agent asks</h3>
            <p>Claude Code, Claude Desktop, OpenClaw, Hermes, or any other agent that speaks MCP calls the <code>ask_user</code> tool — text, choice, scale, or confirm.</p>
          </li>
          <li>
            <span class="step-n">02</span>
            <h3>A panel slides in</h3>
            <p>A non-activating macOS panel floats above your work. It never grabs your keyboard — you answer when you glance at it, not when it interrupts.</p>
          </li>
          <li>
            <span class="step-n">03</span>
            <h3>Structured data comes back</h3>
            <p>The agent receives <code>{'{answer, via, elapsed_s}'}</code> — typed results, not parsed strings. Timeouts are part of the contract.</p>
          </li>
        </ol>
      </div>
    </section>

    <!-- 4 · QUESTION — quickstart -->
    <section class="panel" id="wire" data-flow="question" aria-label="Quickstart">
      <div class="panel-body reveal">
        <p class="caption">Quickstart · 60 seconds</p>
        <h2>Wire it into a project?</h2>
        <div class="code-pair">
          <div class="code-block">
            <p class="caption code-label">.mcp.json</p>
            <pre><code>{`{
  "mcpServers": {
    "cenno": {
      "command": "/Applications/cenno.app/Contents/MacOS/cenno",
      "args": ["--mcp-stdio"]
    }
  }
}`}</code></pre>
          </div>
          <div class="code-block">
            <p class="caption code-label">or straight from the shell</p>
            <pre><code>{`/Applications/cenno.app/Contents/MacOS/cenno \\
  ask "Ship it?" --timeout 30`}</code></pre>
            <p class="code-note">A panel appears; your answer prints as JSON. cenno auto-launches if it isn't running.</p>
          </div>
        </div>
        <p class="code-note">
          There's also a ready-made <a href={`${GITHUB}/tree/main/skills/cenno`}>agent skill</a>
          that teaches your agent to ask well — input kinds, etiquette, graceful timeouts.
        </p>
      </div>
    </section>

    <!-- 5 · EMA — getting started for agents -->
    <section class="panel" id="agents" data-flow="ema" aria-label="Getting started for agents">
      <div class="panel-body reveal">
        <p class="caption">Getting started · For agents</p>
        <h2>Three prompts.<br />Drop one in.</h2>
        <p class="lede agent-lede">
          cenno speaks MCP — any agent that knows the
          <a href={SKILL_URL}>cenno skill</a> can ask you questions through it.
          Copy a prompt below and hand it to Claude Code, Claude Desktop, or any MCP-capable agent.
        </p>
        <div class="recipes">
          <div class="recipe">
            <div class="recipe-header">
              <div class="recipe-meta">
                <p class="caption recipe-label">01 · UX &amp; product discovery</p>
                <p class="recipe-desc">Six questions on priorities, audience, direction, and trade-offs. Useful before a work session or a planning call.</p>
              </div>
              <button class="btn btn-ghost copy recipe-copy" data-copy={PROMPT_UX} type="button">
                <span class="copy-hint" role="status">copy</span>
              </button>
            </div>
            <pre><code>{PROMPT_UX}</code></pre>
          </div>
          <div class="recipe">
            <div class="recipe-header">
              <div class="recipe-meta">
                <p class="caption recipe-label">02 · Wellbeing check-in</p>
                <p class="recipe-desc">Mood, sleep, body, and mind — five questions that surface how you actually are, not just how you say you are.</p>
              </div>
              <button class="btn btn-ghost copy recipe-copy" data-copy={PROMPT_WELLBEING} type="button">
                <span class="copy-hint" role="status">copy</span>
              </button>
            </div>
            <pre><code>{PROMPT_WELLBEING}</code></pre>
          </div>
          <div class="recipe">
            <div class="recipe-header">
              <div class="recipe-meta">
                <p class="caption recipe-label">03 · Goals alignment</p>
                <p class="recipe-desc">Five questions to reconnect with what matters — before drift becomes a pattern.</p>
              </div>
              <button class="btn btn-ghost copy recipe-copy" data-copy={PROMPT_GOALS} type="button">
                <span class="copy-hint" role="status">copy</span>
              </button>
            </div>
            <pre><code>{PROMPT_GOALS}</code></pre>
          </div>
        </div>
        <p class="code-note agents-skill-note">
          Each prompt includes the install step — hand it to a fresh agent and it runs end to end.
          The <a href={SKILL_URL}>cenno skill</a> in the repo teaches agents all input kinds, etiquette, and timeout handling.
        </p>
      </div>
    </section>

    <!-- 6 · REMINDER — data & respect -->
    <section class="panel" id="data" data-flow="reminder" aria-label="Privacy and policy">
      <div class="panel-body reveal">
        <p class="caption">Whose data?</p>
        <h2>Yours. All of it.</h2>
        <ul class="claims">
          <li>
            <h3>Local by design</h3>
            <p>Every exchange lands in a local SQLite file with user-only permissions. cenno makes no network connections on its own.</p>
          </li>
          <li>
            <h3>Queryable history</h3>
            <p><code>cenno export</code> dumps your whole answer history as JSON or CSV. Your answers become your own dataset.</p>
          </li>
          <li>
            <h3>Respectful by policy</h3>
            <p>Pause prompts from the tray — 15 minutes to “until tomorrow”. Fullscreen keeps panels quiet automatically. Agents just see a normal timeout.</p>
          </li>
        </ul>
      </div>
    </section>

    <!-- 7 · PAPER — for developers -->
    <section class="panel" id="dev" data-flow="paper" aria-label="For developers">
      <div class="panel-body reveal">
        <p class="caption">For developers</p>
        <h2>Developer?</h2>
        <ul class="claims dev-claims">
          <li>
            <h3>Ship your own control</h3>
            <p>
              The prompt UI is an <a href="https://a2ui.org">A2UI</a> catalog
              (<code>cenno:catalog/v1</code>): write a plain React view, register a
              thin adapter, and agents can render it. Raw A2UI payloads are
              validated at the Rust boundary, so a new control normally needs no
              Rust changes. <a href={`${GITHUB}/blob/main/docs/design/CONTROLS.md`}>The
              catalog guide</a> has the inventory and the recipe.
            </p>
          </li>
          <li>
            <h3>Drive it from the CLI</h3>
            <p>
              <code>cenno ask "Ship it?" --timeout 30</code> from any script —
              exit codes for answered / timed out, JSON on stdout, and
              <code>cenno export --format csv</code> for the whole answer history.
            </p>
          </li>
          <li>
            <h3>Or speak MCP</h3>
            <p>
              One <code>ask_user</code> tool covers text, choice, scale, and
              confirm — plus flow color, progress dots, timeouts, and full A2UI
              layouts when a simple form isn't enough.
              <a href={`${GITHUB}#the-ask_user-tool`}>The contract is in the README.</a>
            </p>
          </li>
        </ul>
        <p class="code-note dev-cta">
          Something missing or broken?
          <a href={`${GITHUB}/issues/new`}>Create an issue</a> — and see
          <a href={`${GITHUB}/blob/main/CONTRIBUTING.md`}>CONTRIBUTING</a> before
          your first PR.
        </p>
      </div>
    </section>

    <!-- 8 · AMBIENT — the confirm panel -->
    <section class="panel" id="ship" data-flow="ambient" aria-label="Download and links">
      <div class="panel-body ship-body reveal">
        <p class="caption">Confirm</p>
        <h2 class="ship-q">Ship it?</h2>
        <div class="cta-row">
          <a class="btn btn-solid" href={DMG}>Download for macOS</a>
          <a class="btn btn-ghost" href={GITHUB}>View on GitHub</a>
        </div>
        <p class="fine">
          <code>{BREW}</code>
        </p>

        <footer class="footer">
          <div class="builtby">
            <p class="caption">Built by</p>
            <p>
              <a href="https://glebkalinin.com">Gleb Kalinin</a>
              (<a href="https://www.linkedin.com/in/glebkalinin/">LinkedIn</a>) —
              designed, built, and reviewed end-to-end with AI agents in two days.
              The full spec&nbsp;→&nbsp;plan&nbsp;→&nbsp;review trail
              <a href={`${GITHUB}/tree/main/docs/superpowers`}>ships in the repo</a>.
            </p>
          </div>
          <p class="footer-meta">
            <a href={`${GITHUB}/blob/main/LICENSE`}>Apache-2.0</a> ·
            <a href="/privacy">Privacy</a> ·
            <a href="/impressum">Impressum</a> ·
            <a href={`${GITHUB}/blob/main/SECURITY.md`}>Security</a> ·
            <a href={`${GITHUB}/blob/main/CONTRIBUTING.md`}>Contributing</a> ·
            <a href={`${GITHUB}/issues/new`}>Create an issue</a> ·
            <a href={`${GITHUB}/releases`}>All releases</a> ·
            <a href={GITHUB}>GitHub</a>
          </p>
        </footer>
      </div>
    </section>

    <!-- dot pagination — straight from the app's design rules -->
    <nav class="dots" aria-label="Sections">
      {panels.map((p, i) => (
        <a href={`#${p.id}`} class="dot" data-target={p.id} aria-label={`Section ${i + 1}: ${p.label}`}></a>
      ))}
    </nav>

    <script>
      // Active dot follows the visible panel.
      const dots = [...document.querySelectorAll<HTMLAnchorElement>(".dot")];
      const byId = new Map(dots.map((d) => [d.dataset.target, d]));
      const nav = document.querySelector<HTMLElement>(".dots");
      const observer = new IntersectionObserver(
        (entries) => {
          for (const e of entries) {
            if (!e.isIntersecting) continue;
            dots.forEach((d) => {
              d.classList.remove("on");
              d.removeAttribute("aria-current");
            });
            const dot = byId.get(e.target.id);
            dot?.classList.add("on");
            dot?.setAttribute("aria-current", "true");
            nav?.classList.toggle("dots-ink", (e.target as HTMLElement).dataset.flow === "paper");
          }
        },
        { threshold: 0.51 }
      );
      document.querySelectorAll(".panel").forEach((s) => observer.observe(s));

      // Below-the-fold panels reveal once, gently.
      const revealer = new IntersectionObserver(
        (entries) => {
          for (const e of entries) {
            if (!e.isIntersecting) continue;
            e.target.classList.add("in");
            revealer.unobserve(e.target);
          }
        },
        { threshold: 0.2 }
      );
      document.querySelectorAll(".reveal").forEach((el) => revealer.observe(el));

      // ——— interactive demo: a four-question preference interview ———
      type Scene = {
        flow: string;
        q: string;
        kind: "choice" | "scale" | "confirm";
        options?: string[];
        auto: string;
      };
      const SCENES: Scene[] = [
        { flow: "question", q: "Coffee or tea, first thing?", kind: "choice", options: ["Coffee", "Tea", "Water"], auto: "Tea" },
        { flow: "ema", q: "How adventurous are your weekend plans?", kind: "scale", auto: "5" },
        { flow: "mood", q: "Your mornings, in one word?", kind: "choice", options: ["Calm", "Focused", "Chaotic", "Slow"], auto: "Focused" },
        { flow: "reminder", q: "Save these to preferences.md?", kind: "confirm", options: ["Save", "Not now"], auto: "Save" },
      ];
      const demo = document.getElementById("demo");
      const dPanel = demo?.querySelector<HTMLElement>(".demo-panel");
      const dQ = demo?.querySelector<HTMLElement>(".demo-q");
      const dControls = demo?.querySelector<HTMLElement>(".demo-controls");
      const dDots = demo?.querySelector<HTMLElement>(".demo-dots");
      const dTerm = demo?.querySelector<HTMLElement>(".demo-term");
      if (demo && dPanel && dQ && dControls && dDots && dTerm) {
        let scene = 0;
        let sceneStart = 0;
        let timer = 0;
        const AUTO_MS = 5500;

        const termLine = (html: string, dim = false) => {
          const p = document.createElement("p");
          if (dim) p.className = "t-dim";
          p.innerHTML = html;
          dTerm.appendChild(p);
          while (dTerm.children.length > 4) dTerm.removeChild(dTerm.firstChild!);
        };

        const chip = (label: string, solid = false) => {
          const b = document.createElement("button");
          b.type = "button";
          b.className = solid ? "demo-chip demo-chip-solid" : "demo-chip";
          b.textContent = label;
          b.addEventListener("click", () => answer(label, b));
          return b;
        };

        const render = () => {
          const s = SCENES[scene];
          sceneStart = performance.now();
          dPanel.dataset.flow = s.flow;
          dQ.textContent = s.q;
          dControls.innerHTML = "";
          dControls.className = `demo-controls demo-${s.kind}`;
          if (s.kind === "scale") {
            for (let i = 1; i <= 7; i++) dControls.appendChild(chip(String(i)));
          } else {
            s.options!.forEach((o, i) =>
              dControls.appendChild(chip(o, s.kind === "confirm" && i === 0)));
          }
          dDots.innerHTML = SCENES.map((_, i) =>
            `<span class="${i === scene ? "demo-dot demo-dot-on" : "demo-dot"}"></span>`).join("");
          dPanel.classList.remove("demo-swap");
          void dPanel.offsetWidth; // restart the swap animation
          dPanel.classList.add("demo-swap");
          clearTimeout(timer);
          timer = window.setTimeout(() => {
            const target = [...dControls.querySelectorAll<HTMLButtonElement>(".demo-chip")]
              .find((c) => c.textContent === SCENES[scene].auto);
            if (target) answer(SCENES[scene].auto, target, true);
          }, AUTO_MS);
        };

        const answer = (value: string, el: HTMLButtonElement, auto = false) => {
          clearTimeout(timer);
          // clear any pre-selected or previously picked chip before marking the new one
          dControls.querySelectorAll<HTMLButtonElement>(".demo-chip").forEach((c) => {
            c.classList.remove("demo-chip-solid", "demo-chip-picked");
          });
          el.classList.add("demo-chip-picked");
          const via = auto ? "timeout-demo" : "choice";
          const elapsed = ((performance.now() - sceneStart) / 1000).toFixed(1);
          termLine(`⏺ {"answer":"${value.toLowerCase()}","via":"${via}","elapsed_s":${elapsed}}`);
          window.setTimeout(() => {
            scene++;
            if (scene >= SCENES.length) {
              scene = 0;
              termLine("✓ 4 answers recorded — preferences.md updated", true);
              window.setTimeout(render, 2600);
            } else {
              render();
            }
          }, auto ? 700 : 250);
        };

        // Start the loop only when the hero is on screen.
        new IntersectionObserver((entries, obs) => {
          if (entries.some((e) => e.isIntersecting)) {
            render();
            obs.disconnect();
          }
        }).observe(demo);
      }

      // Copy-to-clipboard for the brew chip.
      document.querySelectorAll<HTMLButtonElement>(".copy").forEach((btn) => {
        btn.addEventListener("click", async () => {
          const hint = btn.querySelector(".copy-hint");
          try {
            await navigator.clipboard.writeText(btn.dataset.copy ?? "");
            if (hint) {
              hint.textContent = "copied";
              setTimeout(() => (hint.textContent = "copy"), 1600);
            }
          } catch {
            if (hint) hint.textContent = "press ⌘C";
            const range = document.createRange();
            const code = btn.querySelector("code");
            if (code) {
              range.selectNodeContents(code);
              getSelection()?.removeAllRanges();
              getSelection()?.addRange(range);
            }
          }
        });
      });
    </script>

    <style is:global>
